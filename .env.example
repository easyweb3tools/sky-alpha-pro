SKY_ALPHA_APP_ENV=dev
SKY_ALPHA_APP_VERSION=0.1.0

SKY_ALPHA_SERVER_HOST=0.0.0.0
SKY_ALPHA_SERVER_PORT=8080
SKY_ALPHA_SERVER_READ_TIMEOUT=10s
SKY_ALPHA_SERVER_READ_HEADER_TIMEOUT=5s
SKY_ALPHA_SERVER_WRITE_TIMEOUT=15s
SKY_ALPHA_SERVER_SHUTDOWN_TIMEOUT=10s

SKY_ALPHA_MARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
SKY_ALPHA_MARKET_CLOB_BASE_URL=https://clob.polymarket.com
SKY_ALPHA_MARKET_WEATHER_TAG=weather
SKY_ALPHA_MARKET_SYNC_LIMIT=100
SKY_ALPHA_MARKET_REQUEST_TIMEOUT=12s

SKY_ALPHA_WEATHER_NWS_BASE_URL=https://api.weather.gov
SKY_ALPHA_WEATHER_OPENMETEO_BASE_URL=https://api.open-meteo.com
SKY_ALPHA_WEATHER_OPENMETEO_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com
SKY_ALPHA_WEATHER_VISUALCROSSING_BASE_URL=https://weather.visualcrossing.com
SKY_ALPHA_WEATHER_VISUALCROSSING_API_KEY=
SKY_ALPHA_WEATHER_REQUEST_TIMEOUT=12s
SKY_ALPHA_WEATHER_USER_AGENT=sky-alpha-pro/0.1.0

SKY_ALPHA_DATABASE_HOST=127.0.0.1
SKY_ALPHA_DATABASE_PORT=5432
SKY_ALPHA_DATABASE_USER=postgres
SKY_ALPHA_DATABASE_PASSWORD=postgres
SKY_ALPHA_DATABASE_NAME=sky_alpha_pro
SKY_ALPHA_DATABASE_SSLMODE=disable
SKY_ALPHA_DATABASE_TIMEZONE=UTC

SKY_ALPHA_LOG_LEVEL=info
SKY_ALPHA_LOG_ENCODING=console
